# stg Docker Compose example. Copy to .env on the stg server and fill real values there.
APP_ENV=staging
BOT_INSTANCE_ID=ichiyon
ENABLE_DEV_COMMANDS=false
BOT_DATA_BACKEND=db
# Compatibility fallback for existing stg/prod env files. Prefer BOT_DATA_BACKEND for new edits.
ICHIYON_DATA_BACKEND=db

# Admin UI
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080
ADMIN_BASE_URL=http://141.147.145.113:8080
ADMIN_SESSION_SECRET=replace_on_server

# PostgreSQL in Docker Compose
POSTGRES_DB=ichiyon_robot
POSTGRES_USER=ichiyon_robot
POSTGRES_PASSWORD=replace_on_server
POSTGRES_PORT=5433
DATABASE_URL=postgresql://ichiyon_robot:replace_on_server@db:5432/ichiyon_robot

# Discord bot tokens. Existing DISCORD_TOKEN remains an ichiyon fallback.
ICHIYON_DISCORD_TOKEN=replace_on_server
IRSIA_DISCORD_TOKEN=replace_on_server
DISCORD_TOKEN=
STARTUP_CHANNEL_ID=0
SCHEDULE_CHANNEL_ID=0

# Discord OAuth for admin UI
DISCORD_OAUTH_CLIENT_ID=replace_on_server
DISCORD_OAUTH_CLIENT_SECRET=replace_on_server
DISCORD_OAUTH_REDIRECT_URI=http://141.147.145.113:8080/auth/discord/callback

# X deck search
X_SEARCH_ENABLED=true
X_SEARCH_MAX_RESULTS=10
X_BEARER_TOKEN=replace_on_server
X_SEARCH_MODE=full_archive
X_SEARCH_LOOKBACK_DAYS=14

# Optional yt-dlp cookies file for YouTube bot-check pages. Keep the actual file out of Git.
YTDLP_COOKIES_FILE=/app/secrets/youtube-cookies.txt
YTDLP_COOKIE_CHECK_ENABLED=false
YTDLP_COOKIE_CHECK_TIME=04:30
YTDLP_COOKIE_CHECK_TIMEZONE=Asia/Tokyo
YTDLP_COOKIE_CHECK_OWNER_BOT_ID=ichiyon
YTDLP_COOKIE_CHECK_URL=
YTDLP_COOKIE_RETRY_COOLDOWN_SECONDS=1800
YTDLP_ALERT_CHANNEL_ID=

# Spotify links are resolved to YouTube audio via Spotify Web API metadata.
# Keep the real client secret out of Git.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=JP
SPOTIFY_MAX_ALBUM_TRACKS=100
SPOTIFY_RESOLVE_CONCURRENCY=1
SPOTIFY_RESOLVE_CACHE_TTL_SECONDS=86400
SPOTIFY_MATCH_MIN_SCORE=

# Bot identity
DEVELOPER_USER_ID=123456789012345678
NORMAL_BOT_NICKNAME=いちよんロボ-stg
BOT_ROLE_NAME=いちよんロボ-stg-role
HAYUSU_BOT_NICKNAME=はゆすロボ-stg
