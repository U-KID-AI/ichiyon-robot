# Local development defaults. Copy this file to .env and replace secrets there.
APP_ENV=development
BOT_INSTANCE_ID=ichiyon
ENABLE_DEV_COMMANDS=true
BOT_DATA_BACKEND=db
# Compatibility fallback for existing environments. Prefer BOT_DATA_BACKEND for new setups.
ICHIYON_DATA_BACKEND=db

# Admin UI
ADMIN_HOST=0.0.0.0
ADMIN_PORT=8080
ADMIN_BASE_URL=http://localhost:8080
ADMIN_SESSION_SECRET=replace_with_a_long_random_development_secret

# PostgreSQL local database
POSTGRES_DB=ichiyon_robot
POSTGRES_USER=ichiyon_robot
POSTGRES_PASSWORD=ichiyon_robot_password
POSTGRES_PORT=5432

# Use this from the host machine.
DATABASE_URL=postgresql://ichiyon_robot:ichiyon_robot_password@localhost:5432/ichiyon_robot

# Docker services use this inside the Compose network.
DATABASE_URL_DOCKER=postgresql://ichiyon_robot:ichiyon_robot_password@db:5432/ichiyon_robot

# Discord bot tokens. Existing DISCORD_TOKEN / DISCORD_BOT_TOKEN remain ichiyon fallbacks.
ICHIYON_DISCORD_TOKEN=replace_me
IRSIA_DISCORD_TOKEN=replace_me
DISCORD_TOKEN=
DISCORD_BOT_TOKEN=
STARTUP_CHANNEL_ID=0
SCHEDULE_CHANNEL_ID=0

# Discord OAuth for admin UI. Dummy values are fine for /login display.
DISCORD_OAUTH_CLIENT_ID=your_discord_oauth_client_id
DISCORD_OAUTH_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8080/auth/discord/callback

# X deck search. Keep disabled locally unless testing with a real token.
X_SEARCH_ENABLED=false
X_SEARCH_MAX_RESULTS=10
X_BEARER_TOKEN=
X_SEARCH_MODE=recent
X_SEARCH_LOOKBACK_DAYS=14

# Optional yt-dlp cookies file for YouTube bot-check pages. Keep the actual file out of Git.
YTDLP_COOKIES_FILE=
YTDLP_COOKIE_CHECK_ENABLED=false
YTDLP_COOKIE_CHECK_TIME=04:30
YTDLP_COOKIE_CHECK_TIMEZONE=Asia/Tokyo
YTDLP_COOKIE_CHECK_URL=
YTDLP_COOKIE_RETRY_COOLDOWN_SECONDS=1800
YTDLP_ALERT_CHANNEL_ID=

# Development-only identity defaults.
DEVELOPER_USER_ID=123456789012345678
NORMAL_BOT_NICKNAME=いちよんロボ-dev
BOT_ROLE_NAME=いちよんロボ-dev-role
HAYUSU_BOT_NICKNAME=はゆすロボ-dev
