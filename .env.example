APP_ENV=development
ENABLE_DEV_COMMANDS=true
ICHIYON_DATA_BACKEND=json
DEVELOPER_USER_ID=123456789012345678
NORMAL_BOT_NICKNAME=いちよんロボ-dev
BOT_ROLE_NAME=いちよんロボ-dev-role
HAYUSU_BOT_NICKNAME=はゆすロボ-dev

DISCORD_TOKEN=your_development_bot_token
STARTUP_CHANNEL_ID=0
SCHEDULE_CHANNEL_ID=0

# PostgreSQL development database.
# docker-compose.yml exposes this database on localhost:5432.
POSTGRES_DB=ichiyon_robot
POSTGRES_USER=ichiyon_robot
POSTGRES_PASSWORD=ichiyon_robot_password
DATABASE_URL=postgresql://ichiyon_robot:ichiyon_robot_password@localhost:5432/ichiyon_robot

# Discord OAuth for admin UI. Use dummy values here; put real values in .env only.
ADMIN_BASE_URL=http://localhost:8000
ADMIN_SESSION_SECRET=replace_with_a_long_random_development_secret
DISCORD_OAUTH_CLIENT_ID=your_discord_oauth_client_id
DISCORD_OAUTH_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_OAUTH_REDIRECT_URI=http://localhost:8000/auth/discord/callback
